# ── Deployer ──────────────────────────────────────────────────────────────────
PRIVATE_KEY=your_deployer_private_key
BASESCAN_API_KEY=your_basescan_api_key
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org
ADMIN_ADDRESS=0x...
MINTER_ADDRESS=0x...
PAUSER_ADDRESS=0x...

# ── XIdrToken ──────────────────────────────────────────────────────────────────
INITIAL_USDC_FOR_LIQUIDITY=100000

# ── Liquidity pool (seed-liquidity.ts) ────────────────────────────────────────
INITIAL_PRICE_XIDR_PER_USDC=15900
INITIAL_XIDR_LIQUIDITY=100000000
INITIAL_USDC_LIQUIDITY=6289308

# ── manage-pool.ts ────────────────────────────────────────────────────────────
# LIQUIDITY_MANAGER_ADDRESS=0x...
# LIQUIDITY_MANAGER_PRIVATE_KEY=0x...

# ── FloatIncentive (deploy-float-incentive.ts) ────────────────────────────────
FLOAT_INCENTIVE_INITIAL_APY_BPS=350
FLOAT_INCENTIVE_MIN_FLOAT=10000000
FLOAT_INCENTIVE_TREASURY_SEED=10000000
# Comma-separated partner wallets to register at deploy time (optional)
# INITIAL_PARTNER_WALLETS=0xABCD...,0xEFGH...

# ── keeper.ts ─────────────────────────────────────────────────────────────────
KEEPER_TREASURY_ALERT_THRESHOLD=1000000
# KEEPER_ALERT_EMAIL=ops@yourcompany.com
# KEEPER_SKIP_FEES=false

# ── Fork testing ──────────────────────────────────────────────────────────────
BASE_MAINNET_FORK=false

# ── React dashboard (dashboard/.env) ─────────────────────────────────────────
# Copy these to dashboard/.env (prefix with VITE_)
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
VITE_BASE_RPC_URL=https://mainnet.base.org
VITE_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
VITE_POOL_ADDRESS_MAINNET=0x...
VITE_POOL_ADDRESS_SEPOLIA=0x...
VITE_FLOAT_INCENTIVE_ADDRESS_MAINNET=0x...
VITE_FLOAT_INCENTIVE_ADDRESS_SEPOLIA=0x...
VITE_THEGRAPH_UNISWAP_BASE_URL=https://api.thegraph.com/subgraphs/name/uniswap/uniswap-v3-base
VITE_THEGRAPH_UNISWAP_BASE_SEPOLIA_URL=
NEXT_PUBLIC_FLOAT_INCENTIVE_ADDRESS=0x...
NEXT_PUBLIC_POOL_ADDRESS=0x...
NEXT_PUBLIC_XIDR_TOKEN_ID=0x...
